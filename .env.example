# ── Inference ────────────────────────────────────────────────────────────────
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_API_KEY=your-vllm-api-key

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
ROUTER_KEYPAIR_PATH=~/.config/solana/id.json
# Payment rail: sol (SOL deposits → credits) or lock (legacy $LOCK token deposits)
GRIDLOCK_BILLING_RAIL=sol
# Lamports per 1 billing credit when GRIDLOCK_BILLING_RAIL=sol (1000000 = 0.001 SOL)
GRIDLOCK_LAMPORTS_PER_CREDIT=1000000
# Devnet: disable on-chain LOCK settlement when using SOL billing rail
SOLANA_SETTLEMENT_ENABLED=false
# Pump.fun test token (Phase B — set after: cd scripts && npm run deploy:pump-devnet)
PUMP_TOKEN_MINT=
PUMP_TOKEN_SYMBOL=GRID
PUMP_TOKEN_DECIMALS=6
PUMP_DEV_WALLET_KEY=~/.config/solana/id.json
# Staking rail: pump (self-custody program) or lock (FeeCollector vault)
GRIDLOCK_STAKING_RAIL=pump
GRIDLOCK_STAKING_PROGRAM_ID=BU3JcQJBsFZwNV2DHSPeu3hKLsfarLS2AU5RuVhJrYKM
# Legacy LOCK mint + fee vaults (only when GRIDLOCK_BILLING_RAIL=lock)
LOCK_MINT=4MXFgtdkjQv3YdVHZVNMYrKtFcHyzDwLJmMQfdkYzVnx
FEE_VAULT=5EMpUVkbqyu6G91b6ZWnWxZThRmriE4NiQ2e5PrEyJ5W
STAKER_POOL=g1VDBvggZJCWkkbk9rUga1rDByzcAJ1z7ezuFPyBX1o
WORKER_PAYOUT=4C7zT3bhw9oS7ideXsmwTa68oSdqFvaKEEbVf4mH3Ch5
TREASURY=9omHTNgn7mJvwS9bNUMTv4ZmDyGwhokajQxMS7SUTAYK
BURN_VAULT=B2c3f5yyCD8WtVkqYi5TVV1wtLHdqfNPoJM5MuCcYHS6
CUSTOMER_WALLET=7soX5hwnWQa3uYNfcEPertD7pwxe99SvJfugT1L9sC6x
DEFAULT_WORKER_STAKE=6wvgoqeT5hTH8gmmWTHpKKSTgXSB7eKFtgrQReWkMSgf

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_KEY=your-supabase-secret-key
# Postgres URI for psql migrations only (NOT used by the backend at runtime).
# Get from Supabase owner: Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated bootstrap keys (optional; also accepts DB keys when Supabase is configured)
API_KEYS=
# Dev only: trust X-Gridlock-Wallet on /v1/keys without signature
GRIDLOCK_INSECURE_KEY_MANAGEMENT=false
# HMAC secret for 24h console session tokens (defaults to SUPABASE_KEY in dev)
# GRIDLOCK_WALLET_SESSION_SECRET=
# Off-chain $LOCK credits (set false to disable balance checks)
GRIDLOCK_BILLING_ENABLED=true
# Credits for new wallets on first API use
GRIDLOCK_STARTING_CREDIT_LOCK=10
# Dev: enable POST /v1/billing/topup in console
GRIDLOCK_BILLING_DEV_TOPUP=true
# Explorer cluster for invoice tx links (devnet | mainnet-beta)
SOLANA_CLUSTER=devnet
GRIDLOCK_INVOICE_CRON=true
GRIDLOCK_MIN_DEPOSIT_LOCK=1
# Passive staking (Phase C)
GRIDLOCK_STAKING_ENABLED=true
GRIDLOCK_MIN_STAKE_LOCK=1
# Worker SOL payouts (Phase D)
TREASURY_WALLET_KEY=~/.config/solana/id.json
GRIDLOCK_WORKER_PAYOUTS_ENABLED=true
GRIDLOCK_WORKER_MIN_WITHDRAWAL=0.01
GRIDLOCK_WORKER_STAKE_MATURE_SEC=86400
GRIDLOCK_WORKER_BOOST_MIN_STAKE=5000
GRIDLOCK_WORKER_MAX_SHARE_BPS=6000
# Unstake cooldown seconds (604800 = 7 days; use 60 for dev)
# GRIDLOCK_STAKE_COOLDOWN_SEC=604800
# Enable after FeeCollector redeploy with claim_unstake instruction
# GRIDLOCK_STAKING_CLAIM_ENABLED=true
# Optional: protect POST /v1/billing/invoices/close-all for external cron
# GRIDLOCK_INVOICE_CRON_SECRET=

# ── Web (gridlock-web — set at build time) ───────────────────────────────────
# NEXT_PUBLIC_GRIDLOCK_BILLING_RAIL=sol
# NEXT_PUBLIC_GRIDLOCK_STAKING_RAIL=pump
# NEXT_PUBLIC_PUMP_TOKEN_SYMBOL=GRID

# ── Keeper (Phase C — scripts/keeper.ts) ─────────────────────────────────────
# KEEPER_DRY_RUN=true
# TREASURY_WALLET_KEY=~/.config/solana/id.json
# KEEPER_STAKER_WALLETS=wallet1,wallet2
# TRADING_FEE_BUYBACK_PCT=0.35
# POOL_BURN_SPLIT=0.5

# ── Misc ─────────────────────────────────────────────────────────────────────
WATCHER_SAMPLE_RATE=0.05
NEXT_PUBLIC_API_URL=http://localhost:8080
